# Bot prefix for commands
PREFIX=!

# Bot name
BOT_NAME=Pakistan Jobs Bot

# Node environment
NODE_ENV=production

# Dashboard port
PORT=3000

# Owner JIDs (comma separated - for error alerts)
OWNER_JIDS=923216046022@s.whatsapp.net,923071639265@s.whatsapp.net,923477262704@s.whatsapp.net,923257762682@s.whatsapp.net

# Channel JID for auto job posting
CHANNEL_JID=120363425538472027@newsletter

# Job posting interval in minutes (default 20)
JOB_INTERVAL=20

# Scrape interval in minutes (default 20)
SCRAPE_INTERVAL=20
